MANAGEABLE_ROLES = [
    'student',
    'faculty',
    'dept_head',
    'exam_controller',
    'accounts',
    'admin',
    'super_admin',
]

USER_PAGE_SIZE = 20


# ============================================================
# PERMISSIONS
# ============================================================

def user_can_manage_target(current_user, target_user):
    """
    Super Admin:
        Can edit every user.

    Admin:
        Cannot edit Super Admin.
        Cannot edit their own account from User Management.

    Other roles:
        Cannot use User Management.
    """

    if current_user.role == 'super_admin':
        return True

    if current_user.role == 'admin':
        if target_user.role == 'super_admin':
            return False

        if target_user == current_user:
            return False

        return True

    return False


def user_can_change_status(current_user, target_user):
    """
    Only Super Admin can activate/deactivate accounts.

    Super Admin cannot deactivate their own account here.
    """

    if current_user.role != 'super_admin':
        return False

    if target_user == current_user:
        return False

    return True


# ============================================================
# HELPERS
# ============================================================

def normalize_empty(value):
    value = value.strip() if value else ''
    return value or None


def get_role_choices_for_user(current_user):
    """
    Admin cannot create Super Admin accounts.
    """

    role_choices = list(User.ROLE_CHOICES)

    if current_user.role == 'admin':
        role_choices = [
            choice
            for choice in role_choices
            if choice[0] != 'super_admin'
        ]

    return role_choices


def get_user_with_profile_queryset():
    """
    Load user, staff department, and student academic information
    in the same queryset.

    This prevents the previous N+1 query problem.
    """

    return User.objects.select_related(
        'staff_department',
        'studentprofile',
        'studentprofile__department',
        'studentprofile__batch',
        'studentprofile__current_semester',
    )


def get_student_profile_from_user(user):
    """
    Safely access the reverse OneToOne StudentProfile relation.
    """

    try:
        return user.studentprofile
    except StudentProfile.DoesNotExist:
        return None


def build_user_row(user, current_user):
    """
    Normalize student and staff information into one display structure.
    """

    profile = None

    display_id = user.employee_id or '-'
    department_label = user.staff_department or '-'
    batch_label = '-'
    semester_label = '-'

    if user.role == 'student':
        profile = get_student_profile_from_user(user)

        if profile:
            display_id = profile.student_id or '-'
            department_label = profile.department or '-'
            batch_label = profile.batch or '-'
            semester_label = profile.current_semester or '-'
        else:
            display_id = '-'

    return {
        'user': user,
        'profile': profile,

        'display_id': display_id,
        'department_label': department_label,
        'batch_label': batch_label,
        'semester_label': semester_label,

        'can_edit': user_can_manage_target(
            current_user,
            user,
        ),

        'can_toggle_status': user_can_change_status(
            current_user,
            user,
        ),
    }


def build_user_management_query_string(request, exclude=None):
    """
    Preserve current User Management filters when needed.
    """

    exclude = exclude or []

    allowed_keys = [
        'q',
        'user_type',
        'department',
        'batch',
        'semester',
        'status',
        'page',
    ]

    params = {}

    for key in allowed_keys:
        if key in exclude:
            continue

        value = request.GET.get(key)

        if value:
            params[key] = value

    return urlencode(params)


def user_management_url_with_filters(request):
    """
    Return User Management URL while preserving current filters.
    """

    base_url = reverse('user_management')

    query_string = build_user_management_query_string(request)

    if query_string:
        return f'{base_url}?{query_string}'

    return base_url


def user_detail_url(user_id):
    return reverse(
        'user_detail',
        kwargs={
            'user_id': user_id,
        },
    )


