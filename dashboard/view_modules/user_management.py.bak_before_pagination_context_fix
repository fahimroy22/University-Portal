@login_required
def user_detail(request, user_id):
    """
    Dedicated account detail page.

    Handles:
        - viewing user information
        - editing user information
        - password reset
        - activate/deactivate
    """

    if request.user.role not in [
        'admin',
        'super_admin',
    ]:
        return redirect(
            'dashboard'
        )

    target_user = get_object_or_404(
        get_user_with_profile_queryset(),
        id=user_id,
    )

    if (
        request.user.role == 'admin'
        and target_user.role == 'super_admin'
    ):
        messages.error(
            request,
            (
                "You do not have permission "
                "to view this user."
            ),
        )

        return redirect(
            'user_management'
        )

    departments = Department.objects.all().order_by(
        'code'
    )

    batches = Batch.objects.select_related(
        'department'
    ).order_by(
        'department__code',
        'batch_name',
    )

    semesters = Semester.objects.all().order_by(
        'number'
    )

    selected_row = build_user_row(
        target_user,
        request.user,
    )

    # --------------------------------------------------------
    # POST ACTIONS
    # --------------------------------------------------------

    if request.method == 'POST':

        action = request.POST.get(
            'action'
        )

        # ====================================================
        # UPDATE USER
        # ====================================================

        if action == 'update_user':

            if not user_can_manage_target(
                request.user,
                target_user,
            ):
                messages.error(
                    request,
                    (
                        "You do not have permission "
                        "to edit this user."
                    ),
                )

                return redirect(
                    'user_detail',
                    user_id=target_user.id,
                )

            first_name = normalize_empty(
                request.POST.get(
                    'first_name'
                )
            )

            last_name = normalize_empty(
                request.POST.get(
                    'last_name'
                )
            )

            email = normalize_empty(
                request.POST.get(
                    'email'
                )
            )

            phone = normalize_empty(
                request.POST.get(
                    'phone'
                )
            )

            gender = normalize_empty(
                request.POST.get(
                    'gender'
                )
            )

            date_of_birth = normalize_empty(
                request.POST.get(
                    'date_of_birth'
                )
            )

            address = normalize_empty(
                request.POST.get(
                    'address'
                )
            )

            profile_photo = request.FILES.get(
                'profile_photo'
            )

            # ------------------------------------------------
            # EMAIL DUPLICATION
            # ------------------------------------------------

            if email:

                duplicate_email = (
                    User.objects
                    .exclude(
                        id=target_user.id
                    )
                    .filter(
                        email=email
                    )
                    .exists()
                )

                if duplicate_email:
                    messages.error(
                        request,
                        (
                            "This email is already used "
                            "by another account."
                        ),
                    )

                    return redirect(
                        'user_detail',
                        user_id=target_user.id,
                    )

            # ------------------------------------------------
            # BASIC USER FIELDS
            # ------------------------------------------------

            target_user.first_name = (
                first_name or ''
            )

            target_user.last_name = (
                last_name or ''
            )

            target_user.email = (
                email or ''
            )

            target_user.phone = phone

            target_user.gender = gender

            target_user.date_of_birth = (
                date_of_birth
            )

            target_user.address = address

            if profile_photo:
                target_user.profile_photo = (
                    profile_photo
                )

            # ------------------------------------------------
            # STUDENT
            # ------------------------------------------------

            if target_user.role == 'student':

                student_id = normalize_empty(
                    request.POST.get(
                        'student_id'
                    )
                )

                department_id = normalize_empty(
                    request.POST.get(
                        'department'
                    )
                )

                batch_id = normalize_empty(
                    request.POST.get(
                        'batch'
                    )
                )

                current_semester_id = normalize_empty(
                    request.POST.get(
                        'current_semester'
                    )
                )

                admission_session = normalize_empty(
                    request.POST.get(
                        'admission_session'
                    )
                )

                guardian_name = normalize_empty(
                    request.POST.get(
                        'guardian_name'
                    )
                )

                guardian_phone = normalize_empty(
                    request.POST.get(
                        'guardian_phone'
                    )
                )

                if not student_id:
                    messages.error(
                        request,
                        (
                            "Student ID is required "
                            "for student profile."
                        ),
                    )

                    return redirect(
                        'user_detail',
                        user_id=target_user.id,
                    )

                duplicate_student_id = (
                    StudentProfile.objects
                    .exclude(
                        user=target_user
                    )
                    .filter(
                        student_id=student_id
                    )
                    .exists()
                )

                if duplicate_student_id:
                    messages.error(
                        request,
                        (
                            "Another student already "
                            "uses this Student ID."
                        ),
                    )

                    return redirect(
                        'user_detail',
                        user_id=target_user.id,
                    )

                department = None

                if department_id:
                    department = (
                        Department.objects.filter(
                            id=department_id
                        ).first()
                    )

                batch = None

                if batch_id:
                    batch = (
                        Batch.objects.filter(
                            id=batch_id
                        ).first()
                    )

                current_semester = None

                if current_semester_id:
                    current_semester = (
                        Semester.objects.filter(
                            id=current_semester_id
                        ).first()
                    )

                if (
                    department
                    and batch
                    and batch.department_id
                    != department.id
                ):
                    messages.error(
                        request,
                        (
                            "The selected batch does "
                            "not belong to the selected "
                            "department."
                        ),
                    )

                    return redirect(
                        'user_detail',
                        user_id=target_user.id,
                    )

                profile, created = (
                    StudentProfile.objects
                    .get_or_create(
                        user=target_user,
                        defaults={
                            'student_id':
                                student_id,
                        },
                    )
                )

                profile.student_id = (
                    student_id
                )

                profile.department = (
                    department
                )

                profile.batch = batch

                profile.current_semester = (
                    current_semester
                )

                profile.admission_session = (
                    admission_session
                )

                profile.guardian_name = (
                    guardian_name
                )

                profile.guardian_phone = (
                    guardian_phone
                )

                profile.address = (
                    target_user.address
                )

                profile.is_active = (
                    target_user.is_active
                )

                if (
                    profile_photo
                    and hasattr(
                        profile,
                        'photo',
                    )
                ):
                    profile.photo = (
                        profile_photo
                    )

                profile.save()

                target_user.employee_id = None
                target_user.staff_department = None
                target_user.designation = None
                target_user.office_room = None

            # ------------------------------------------------
            # STAFF
            # ------------------------------------------------

            else:

                employee_id = normalize_empty(
                    request.POST.get(
                        'employee_id'
                    )
                )

                staff_department_id = normalize_empty(
                    request.POST.get(
                        'staff_department'
                    )
                )

                designation = normalize_empty(
                    request.POST.get(
                        'designation'
                    )
                )

                office_room = normalize_empty(
                    request.POST.get(
                        'office_room'
                    )
                )

                if not employee_id:
                    messages.error(
                        request,
                        (
                            "Employee ID is required "
                            "for non-student users."
                        ),
                    )

                    return redirect(
                        'user_detail',
                        user_id=target_user.id,
                    )

                duplicate_employee_id = (
                    User.objects
                    .exclude(
                        id=target_user.id
                    )
                    .filter(
                        employee_id=employee_id
                    )
                    .exists()
                )

                if duplicate_employee_id:
                    messages.error(
                        request,
                        (
                            "Another user already uses "
                            "this Employee ID."
                        ),
                    )

                    return redirect(
                        'user_detail',
                        user_id=target_user.id,
                    )

                staff_department = None

                if target_user.role in [
                    'faculty',
                    'dept_head',
                ]:

                    if not staff_department_id:
                        messages.error(
                            request,
                            (
                                "Department is required "
                                "for Faculty and "
                                "Department Head users."
                            ),
                        )

                        return redirect(
                            'user_detail',
                            user_id=target_user.id,
                        )

                    staff_department = (
                        Department.objects.filter(
                            id=staff_department_id
                        ).first()
                    )

                    if not staff_department:
                        messages.error(
                            request,
                            (
                                "Invalid staff "
                                "department."
                            ),
                        )

                        return redirect(
                            'user_detail',
                            user_id=target_user.id,
                        )

                target_user.employee_id = (
                    employee_id
                )

                target_user.staff_department = (
                    staff_department
                )

                target_user.designation = (
                    designation
                )

                target_user.office_room = (
                    office_room
                )

            target_user.save()

            create_audit_log(
                request,

                action='UPDATE',

                module='User Management',

                description=(
                    f'Updated user account: '
                    f'{target_user.username}'
                ),

                target_model='User',

                target_id=target_user.id,

                target_repr=
                    target_user.username,
            )

            messages.success(
                request,
                "User updated successfully.",
            )

            return redirect(
                'user_detail',
                user_id=target_user.id,
            )

        # ====================================================
        # RESET PASSWORD
        # ====================================================

        elif action == 'reset_password':

            if not user_can_manage_target(
                request.user,
                target_user,
            ):
                messages.error(
                    request,
                    (
                        "You do not have permission "
                        "to reset this user's password."
                    ),
                )

                return redirect(
                    'user_detail',
                    user_id=target_user.id,
                )

            new_password = request.POST.get(
                'new_password'
            )

            confirm_password = request.POST.get(
                'confirm_password'
            )

            if (
                not new_password
                or not confirm_password
            ):
                messages.error(
                    request,
                    (
                        "Password and confirm "
                        "password are required."
                    ),
                )

                return redirect(
                    'user_detail',
                    user_id=target_user.id,
                )

            if (
                new_password
                != confirm_password
            ):
                messages.error(
                    request,
                    (
                        "Password and confirm "
                        "password do not match."
                    ),
                )

                return redirect(
                    'user_detail',
                    user_id=target_user.id,
                )

            target_user.set_password(
                new_password
            )

            target_user.save()

            create_audit_log(
                request,

                action='PASSWORD_RESET',

                module='User Management',

                description=(
                    f'Reset password for user: '
                    f'{target_user.username}'
                ),

                target_model='User',

                target_id=target_user.id,

                target_repr=
                    target_user.username,
            )

            messages.success(
                request,
                (
                    "Password reset successfully "
                    f"for {target_user.username}."
                ),
            )

            return redirect(
                'user_detail',
                user_id=target_user.id,
            )

        # ====================================================
        # TOGGLE STATUS
        # ====================================================

        elif action == 'toggle_user_status':

            if not user_can_change_status(
                request.user,
                target_user,
            ):
                messages.error(
                    request,
                    (
                        "Only Super Admin can activate "
                        "or deactivate user access."
                    ),
                )

                return redirect(
                    'user_detail',
                    user_id=target_user.id,
                )

            target_user.is_active = (
                not target_user.is_active
            )

            target_user.save(
                update_fields=[
                    'is_active',
                ]
            )

            if target_user.role == 'student':

                StudentProfile.objects.filter(
                    user=target_user
                ).update(
                    is_active=
                        target_user.is_active
                )

            create_audit_log(
                request,

                action=(
                    'ACTIVATE'
                    if target_user.is_active
                    else 'DEACTIVATE'
                ),

                module='User Management',

                description=(
                    'Changed active status for '
                    f'user: {target_user.username}'
                ),

                target_model='User',

                target_id=target_user.id,

                target_repr=
                    target_user.username,
            )

            if target_user.is_active:
                messages.success(
                    request,
                    (
                        "User activated "
                        "successfully."
                    ),
                )

            else:
                messages.warning(
                    request,
                    (
                        "User deactivated "
                        "successfully."
                    ),
                )

            return redirect(
                'user_detail',
                user_id=target_user.id,
            )

        else:
            messages.error(
                request,
                "Invalid user management action.",
            )

            return redirect(
                'user_detail',
                user_id=target_user.id,
            )

    # --------------------------------------------------------
    # REFRESH DETAIL DATA
    # --------------------------------------------------------

    target_user = get_object_or_404(
        get_user_with_profile_queryset(),
        id=user_id,
    )

    selected_row = build_user_row(
        target_user,
        request.user,
    )

    context = {
        'selected_row': selected_row,
        'target_user': target_user,

        'departments': departments,
        'batches': batches,
        'semesters': semesters,

        'gender_choices':
            User.GENDER_CHOICES,

        'is_super_admin':
            request.user.role == 'super_admin',

        'is_admin_user':
            request.user.role == 'admin',
    }

    return render(
        request,
        'dashboard/user_detail.html',
        context,
    )