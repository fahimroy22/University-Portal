@login_required
def create_user(request):
    """
    Dedicated Create User page.
    """

    if request.user.role not in [
        'admin',
        'super_admin',
    ]:
        return redirect('dashboard')

    departments = Department.objects.all().order_by(
        'code'
    )

    batches = Batch.objects.select_related(
        'department'
    ).order_by(
        'department__code',
        'batch_name',
    )

    semesters = Semester.objects.all().order_by(
        'number'
    )

    role_choices = get_role_choices_for_user(
        request.user
    )

    if request.method == 'POST':

        username = normalize_empty(
            request.POST.get(
                'username'
            )
        )

        password = request.POST.get(
            'password'
        )

        confirm_password = request.POST.get(
            'confirm_password'
        )

        role = normalize_empty(
            request.POST.get(
                'role'
            )
        )

        # ----------------------------------------------------
        # PERSONAL INFORMATION
        # ----------------------------------------------------

        first_name = normalize_empty(
            request.POST.get(
                'first_name'
            )
        )

        last_name = normalize_empty(
            request.POST.get(
                'last_name'
            )
        )

        email = normalize_empty(
            request.POST.get(
                'email'
            )
        )

        phone = normalize_empty(
            request.POST.get(
                'phone'
            )
        )

        gender = normalize_empty(
            request.POST.get(
                'gender'
            )
        )

        date_of_birth = normalize_empty(
            request.POST.get(
                'date_of_birth'
            )
        )

        address = normalize_empty(
            request.POST.get(
                'address'
            )
        )

        profile_photo = request.FILES.get(
            'profile_photo'
        )

        is_active = (
            request.POST.get(
                'is_active'
            )
            == 'on'
        )

        # ----------------------------------------------------
        # STAFF INFORMATION
        # ----------------------------------------------------

        employee_id = normalize_empty(
            request.POST.get(
                'employee_id'
            )
        )

        staff_department_id = normalize_empty(
            request.POST.get(
                'staff_department'
            )
        )

        designation = normalize_empty(
            request.POST.get(
                'designation'
            )
        )

        office_room = normalize_empty(
            request.POST.get(
                'office_room'
            )
        )

        # ----------------------------------------------------
        # STUDENT INFORMATION
        # ----------------------------------------------------

        student_id = normalize_empty(
            request.POST.get(
                'student_id'
            )
        )

        department_id = normalize_empty(
            request.POST.get(
                'department'
            )
        )

        batch_id = normalize_empty(
            request.POST.get(
                'batch'
            )
        )

        current_semester_id = normalize_empty(
            request.POST.get(
                'current_semester'
            )
        )

        admission_session = normalize_empty(
            request.POST.get(
                'admission_session'
            )
        )

        guardian_name = normalize_empty(
            request.POST.get(
                'guardian_name'
            )
        )

        guardian_phone = normalize_empty(
            request.POST.get(
                'guardian_phone'
            )
        )

        # ----------------------------------------------------
        # BASIC VALIDATION
        # ----------------------------------------------------

        if (
            not username
            or not password
            or not confirm_password
            or not role
        ):
            messages.error(
                request,
                (
                    "Username, password, "
                    "confirm password, and role "
                    "are required."
                ),
            )

            return redirect(
                'create_user'
            )

        valid_role_values = [
            choice[0]
            for choice in role_choices
        ]

        if role not in valid_role_values:
            messages.error(
                request,
                "Invalid user role.",
            )

            return redirect(
                'create_user'
            )

        if (
            request.user.role == 'admin'
            and role == 'super_admin'
        ):
            messages.error(
                request,
                (
                    "Admin cannot create "
                    "Super Admin users."
                ),
            )

            return redirect(
                'create_user'
            )

        if password != confirm_password:
            messages.error(
                request,
                (
                    "Password and confirm "
                    "password do not match."
                ),
            )

            return redirect(
                'create_user'
            )

        if User.objects.filter(
            username=username
        ).exists():
            messages.error(
                request,
                "This username already exists.",
            )

            return redirect(
                'create_user'
            )

        if (
            email
            and User.objects.filter(
                email=email
            ).exists()
        ):
            messages.error(
                request,
                (
                    "This email is already used "
                    "by another account."
                ),
            )

            return redirect(
                'create_user'
            )

        # ----------------------------------------------------
        # ROLE-SPECIFIC VALIDATION
        # ----------------------------------------------------

        staff_department = None

        if role == 'student':

            if (
                not student_id
                or not department_id
                or not batch_id
                or not current_semester_id
            ):
                messages.error(
                    request,
                    (
                        "Student ID, department, batch, "
                        "and current semester are required "
                        "for student accounts."
                    ),
                )

                return redirect(
                    'create_user'
                )

            if StudentProfile.objects.filter(
                student_id=student_id
            ).exists():
                messages.error(
                    request,
                    (
                        "This Student ID "
                        "already exists."
                    ),
                )

                return redirect(
                    'create_user'
                )

            department = Department.objects.filter(
                id=department_id
            ).first()

            batch = Batch.objects.filter(
                id=batch_id
            ).first()

            current_semester = Semester.objects.filter(
                id=current_semester_id
            ).first()

            if not department:
                messages.error(
                    request,
                    "Invalid department.",
                )
                return redirect(
                    'create_user'
                )

            if not batch:
                messages.error(
                    request,
                    "Invalid batch.",
                )
                return redirect(
                    'create_user'
                )

            if not current_semester:
                messages.error(
                    request,
                    "Invalid semester.",
                )
                return redirect(
                    'create_user'
                )

            if batch.department_id != department.id:
                messages.error(
                    request,
                    (
                        "The selected batch does not "
                        "belong to the selected department."
                    ),
                )

                return redirect(
                    'create_user'
                )

            employee_id = None
            designation = None
            office_room = None

        else:

            if not employee_id:
                messages.error(
                    request,
                    (
                        "Employee ID is required "
                        "for non-student users."
                    ),
                )

                return redirect(
                    'create_user'
                )

            if User.objects.filter(
                employee_id=employee_id
            ).exists():
                messages.error(
                    request,
                    (
                        "This Employee ID "
                        "already exists."
                    ),
                )

                return redirect(
                    'create_user'
                )

            if role in [
                'faculty',
                'dept_head',
            ]:

                if not staff_department_id:
                    messages.error(
                        request,
                        (
                            "Department is required "
                            "for Faculty and "
                            "Department Head users."
                        ),
                    )

                    return redirect(
                        'create_user'
                    )

                staff_department = (
                    Department.objects.filter(
                        id=staff_department_id
                    ).first()
                )

                if not staff_department:
                    messages.error(
                        request,
                        "Invalid staff department.",
                    )

                    return redirect(
                        'create_user'
                    )

        # ----------------------------------------------------
        # CREATE USER
        # ----------------------------------------------------

        user = User.objects.create_user(
            username=username,
            password=password,

            first_name=first_name or '',
            last_name=last_name or '',
            email=email or '',

            role=role,

            employee_id=employee_id,
            staff_department=staff_department,
            designation=designation,
            office_room=office_room,

            phone=phone,
            gender=gender,
            date_of_birth=date_of_birth,
            address=address,

            is_active=is_active,
        )

        if profile_photo:
            user.profile_photo = profile_photo
            user.save(
                update_fields=[
                    'profile_photo',
                ]
            )

        # ----------------------------------------------------
        # CREATE STUDENT PROFILE
        # ----------------------------------------------------

        if role == 'student':

            profile = StudentProfile.objects.create(
                user=user,

                student_id=student_id,

                department=department,
                batch=batch,
                current_semester=current_semester,

                admission_session=
                    admission_session,

                guardian_name=
                    guardian_name,

                guardian_phone=
                    guardian_phone,

                address=address,

                is_active=is_active,
            )

            if (
                profile_photo
                and hasattr(
                    profile,
                    'photo',
                )
            ):
                profile.photo = profile_photo
                profile.save(
                    update_fields=[
                        'photo',
                    ]
                )

        # ----------------------------------------------------
        # AUDIT
        # ----------------------------------------------------

        create_audit_log(
            request,

            action='CREATE',

            module='User Management',

            description=(
                f'Created '
                f'{user.get_role_display()} '
                f'account: {user.username}'
            ),

            target_model='User',

            target_id=user.id,

            target_repr=user.username,
        )

        messages.success(
            request,
            (
                "User account created "
                "successfully."
            ),
        )

        return redirect(
            'user_detail',
            user_id=user.id,
        )

    context = {
        'departments': departments,
        'batches': batches,
        'semesters': semesters,

        'role_choices': role_choices,
        'gender_choices': User.GENDER_CHOICES,

        'is_super_admin':
            request.user.role == 'super_admin',

        'is_admin_user':
            request.user.role == 'admin',
    }

    return render(
        request,
        'dashboard/user_create.html',
        context,
    )


