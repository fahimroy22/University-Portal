@login_required
def user_management(request):
    """
    Main User Management page.

    Responsibilities:
        - statistics
        - search
        - filtering
        - pagination
        - user list

    User editing is handled by user_detail().
    User creation is handled by create_user().
    """

    if request.user.role not in [
        'admin',
        'super_admin',
    ]:
        return redirect('dashboard')

    # --------------------------------------------------------
    # FILTER OPTIONS
    # --------------------------------------------------------

    departments = Department.objects.all().order_by(
        'code'
    )

    batches = Batch.objects.select_related(
        'department'
    ).order_by(
        'department__code',
        'batch_name',
    )

    semesters = Semester.objects.all().order_by(
        'number'
    )

    # --------------------------------------------------------
    # GET FILTER VALUES
    # --------------------------------------------------------

    search_query = request.GET.get(
        'q',
        '',
    ).strip()

    user_type = request.GET.get(
        'user_type',
        'all',
    ).strip()

    department_filter = request.GET.get(
        'department',
        '',
    ).strip()

    batch_filter = request.GET.get(
        'batch',
        '',
    ).strip()

    semester_filter = request.GET.get(
        'semester',
        '',
    ).strip()

    status_filter = request.GET.get(
        'status',
        '',
    ).strip()

    # --------------------------------------------------------
    # BASE QUERYSET
    # --------------------------------------------------------

    users = get_user_with_profile_queryset().order_by(
        'role',
        'username',
    )

    if request.user.role == 'admin':
        users = users.exclude(
            role='super_admin'
        )

    # --------------------------------------------------------
    # ROLE FILTER
    # --------------------------------------------------------

    role_filter_map = {
        'students': 'student',
        'student': 'student',

        'faculty': 'faculty',

        'accounts': 'accounts',

        'exam': 'exam_controller',
        'exam_controller': 'exam_controller',

        'dept_head': 'dept_head',

        'admin': 'admin',

        'super_admin': 'super_admin',
    }

    selected_role = role_filter_map.get(
        user_type
    )

    if selected_role:
        users = users.filter(
            role=selected_role
        )

    # --------------------------------------------------------
    # STATUS FILTER
    # --------------------------------------------------------

    if status_filter == 'active':
        users = users.filter(
            is_active=True
        )

    elif status_filter == 'inactive':
        users = users.filter(
            is_active=False
        )

    # --------------------------------------------------------
    # DEPARTMENT FILTER
    # --------------------------------------------------------

    if department_filter:
        users = users.filter(
            Q(
                studentprofile__department_id=
                department_filter
            )
            |
            Q(
                staff_department_id=
                department_filter
            )
        ).distinct()

    # --------------------------------------------------------
    # BATCH FILTER
    # --------------------------------------------------------

    if batch_filter:
        users = users.filter(
            studentprofile__batch_id=
            batch_filter
        )

    # --------------------------------------------------------
    # SEMESTER FILTER
    # --------------------------------------------------------

    if semester_filter:
        users = users.filter(
            studentprofile__current_semester_id=
            semester_filter
        )

    # --------------------------------------------------------
    # SEARCH
    # --------------------------------------------------------

    if search_query:
        users = users.filter(
            Q(
                username__icontains=
                search_query
            )
            |
            Q(
                employee_id__icontains=
                search_query
            )
            |
            Q(
                first_name__icontains=
                search_query
            )
            |
            Q(
                last_name__icontains=
                search_query
            )
            |
            Q(
                email__icontains=
                search_query
            )
            |
            Q(
                phone__icontains=
                search_query
            )
            |
            Q(
                role__icontains=
                search_query
            )
            |
            Q(
                designation__icontains=
                search_query
            )
            |
            Q(
                office_room__icontains=
                search_query
            )
            |
            Q(
                staff_department__name__icontains=
                search_query
            )
            |
            Q(
                staff_department__code__icontains=
                search_query
            )
            |
            Q(
                studentprofile__student_id__icontains=
                search_query
            )
            |
            Q(
                studentprofile__department__name__icontains=
                search_query
            )
            |
            Q(
                studentprofile__department__code__icontains=
                search_query
            )
            |
            Q(
                studentprofile__batch__batch_name__icontains=
                search_query
            )
            |
            Q(
                studentprofile__current_semester__name__icontains=
                search_query
            )
        ).distinct()

    # --------------------------------------------------------
    # RESULT COUNT BEFORE PAGINATION
    # --------------------------------------------------------

    filtered_user_count = users.count()

    # --------------------------------------------------------
    # PAGINATION
    # --------------------------------------------------------

    paginator = Paginator(
        users,
        USER_PAGE_SIZE,
    )

    page_number = request.GET.get(
        'page'
    )

    page_obj = paginator.get_page(
        page_number
    )

    user_rows = [
        build_user_row(
            user,
            request.user,
        )
        for user in page_obj.object_list
    ]

    # --------------------------------------------------------
    # PAGINATION QUERY STRING
    #
    # Template can use:
    #
    # ?{{ pagination_query_string }}&page=2
    # --------------------------------------------------------

    pagination_params = {}

    if search_query:
        pagination_params['q'] = search_query

    if user_type and user_type != 'all':
        pagination_params['user_type'] = user_type

    if department_filter:
        pagination_params['department'] = department_filter

    if batch_filter:
        pagination_params['batch'] = batch_filter

    if semester_filter:
        pagination_params['semester'] = semester_filter

    if status_filter:
        pagination_params['status'] = status_filter

    pagination_query_string = urlencode(
        pagination_params
    )

    # --------------------------------------------------------
    # GLOBAL STATISTICS
    # --------------------------------------------------------

    allowed_statistics_users = User.objects.all()

    if request.user.role == 'admin':
        allowed_statistics_users = (
            allowed_statistics_users.exclude(
                role='super_admin'
            )
        )

    students_count = (
        allowed_statistics_users
        .filter(
            role='student'
        )
        .count()
    )

    faculty_count = (
        allowed_statistics_users
        .filter(
            role='faculty'
        )
        .count()
    )

    staff_count = (
        allowed_statistics_users
        .exclude(
            role='student'
        )
        .count()
    )

    active_count = (
        allowed_statistics_users
        .filter(
            is_active=True
        )
        .count()
    )

    inactive_count = (
        allowed_statistics_users
        .filter(
            is_active=False
        )
        .count()
    )

    # --------------------------------------------------------
    # CONTEXT
    # --------------------------------------------------------

    context = {
        # Records
        'user_rows': user_rows,
        'page_obj': page_obj,
        'paginator': paginator,

        # Counts
        'filtered_user_count': filtered_user_count,
        'students_count': students_count,
        'faculty_count': faculty_count,
        'staff_count': staff_count,
        'active_count': active_count,
        'inactive_count': inactive_count,

        # Filter data
        'departments': departments,
        'batches': batches,
        'semesters': semesters,

        # Current filters
        'search_query': search_query,
        'user_type': user_type,
        'department_filter': department_filter,
        'batch_filter': batch_filter,
        'semester_filter': semester_filter,
        'status_filter': status_filter,

        # Pagination
        'pagination_query_string':
            pagination_query_string,

        # Permissions
        'is_super_admin':
            request.user.role == 'super_admin',

        'is_admin_user':
            request.user.role == 'admin',
    }

    return render(
        request,
        'dashboard/user_management.html',
        context,
    )


