@login_required
def exam_result_preview(request):
    if request.user.role != 'exam_controller':
        return redirect('dashboard')

    course_offering_id = request.GET.get('course_offering')
    exam_type = request.GET.get('exam_type')
    department_id = request.GET.get('department')

    if not course_offering_id or not exam_type:
        messages.error(request, 'Please select course and exam type to preview result.')

        if department_id:
            return redirect(f'{reverse("exam_publish_result")}?department={department_id}')

        return redirect('exam_publish_result')

    course_offering = get_object_or_404(
        CourseOffering.objects.select_related(
            'course',
            'batch',
            'semester',
            'faculty'
        ),
        id=course_offering_id
    )

    registrations = CourseRegistration.objects.filter(
        course_offering=course_offering,
        status='approved'
    ).select_related(
        'student',
        'student__user'
    ).order_by('student__student_id')

    result_rows = []

    submitted_count = 0
    missing_count = 0

    for reg in registrations:
        student = reg.student

        mark = Mark.objects.filter(
            student=student,
            course_offering=course_offering,
            is_submitted=True
        ).first()

        midterm_total = Decimal('0')
        final_total = Decimal('0')
        total_marks = Decimal('0')

        if mark:
            submitted_count += 1

            midterm_total = (
                mark.class_test +
                mark.assignment +
                mark.attendance +
                mark.midterm
            )

            final_total = mark.final
            total_marks = mark.total
