        p.setStrokeColor(border)
        p.setLineWidth(1)
        p.line(table_x, y - 9, table_x + table_w, y - 9)

        y -= 20

    y -= 14

    p.setFillColor(muted)
    p.setFont('Helvetica', 8)
    p.drawString(
        table_x,
        y,
        'Note: Students must follow the published routine and arrive at the exam hall before the scheduled time.'
