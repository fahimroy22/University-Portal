    if request.user.role != 'exam_controller':
        return redirect('dashboard')

    department_id = request.GET.get('department', '').strip()
    semester_id = request.GET.get('semester', '').strip()
    exam_type = request.GET.get('exam_type', '').strip()
    section = request.GET.get('section', '').strip()

    if not department_id or not semester_id or not exam_type:
        messages.error(request, 'Please select department, semester, and exam type.')
        return redirect('exam_create_routine')

    department = get_object_or_404(Department, id=department_id)

    course_offerings = _get_semester_routine_course_offerings(
        department_id,
        semester_id,
        section
