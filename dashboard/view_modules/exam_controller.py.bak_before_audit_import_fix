@login_required
def download_semester_transcript_by_student(request, student_id, semester_id):
    if request.user.role != 'exam_controller':
        return redirect('dashboard')

    return _generate_semester_transcript_response(student_id, semester_id)


def _generate_semester_transcript_response(student_id, semester_id):
    student = get_object_or_404(
        StudentProfile.objects.select_related(
            'user',
            'department',
            'batch',
            'current_semester'
        ),
        id=student_id
    )

    marks = Mark.objects.filter(
        student=student,
        is_submitted=True,
        course_offering__semester_id=semester_id,
        course_offering__resultpublication__exam_type='final',
        course_offering__resultpublication__is_published=True
    ).select_related(
        'course_offering',
        'course_offering__course',
        'course_offering__semester'
    ).distinct().order_by(
        'course_offering__course__code'
    )

    if not marks:
        return HttpResponse('No published final result found for this student and semester.')

    semester = marks.first().course_offering.semester

    semester_total_credits = Decimal('0')
    semester_weighted_points = Decimal('0')

    for mark in marks:
        credit = Decimal(str(mark.course_offering.course.credit or 0))
        grade_point = Decimal(str(mark.grade_point or 0))

        semester_total_credits += credit
        semester_weighted_points += credit * grade_point

    if semester_total_credits > 0:
        semester_cgpa = round(semester_weighted_points / semester_total_credits, 2)
    else:
        semester_cgpa = Decimal('0.00')

    all_final_marks = Mark.objects.filter(
        student=student,
        is_submitted=True,
        course_offering__resultpublication__exam_type='final',
        course_offering__resultpublication__is_published=True
    ).select_related(
        'course_offering',
        'course_offering__course'
    ).distinct()

    total_credits = Decimal('0')
    total_weighted_points = Decimal('0')

    for mark in all_final_marks:
        credit = Decimal(str(mark.course_offering.course.credit or 0))
        grade_point = Decimal(str(mark.grade_point or 0))

        total_credits += credit
        total_weighted_points += credit * grade_point

    if total_credits > 0:
        overall_cgpa = round(total_weighted_points / total_credits, 2)
    else:
        overall_cgpa = Decimal('0.00')

    safe_semester_name = str(semester).replace(' ', '_')
    response = HttpResponse(content_type='application/pdf')
    response['Content-Disposition'] = (
        f'attachment; filename="UGV_Official_Transcript_{student.student_id}_{safe_semester_name}.pdf"'
    )

    p = canvas.Canvas(response, pagesize=A4)
    width, height = A4

    accent = colors.HexColor('#9f1c1c')
    dark = colors.HexColor('#0f172a')
    muted = colors.HexColor('#64748b')
    border = colors.HexColor('#dbe3ef')
    soft = colors.HexColor('#f8fafc')
    table_head = colors.HexColor('#f1f5f9')

    card_x = 34
    card_y = 34
    card_w = width - 68
    card_h = height - 68

    inner_x = 62
    right_x = width - 62
    table_x = inner_x
    table_w = right_x - inner_x

    logo_path = os.path.join(
        settings.BASE_DIR,
        'static',
        'images',
        'UGV-Logo-02.png'
    )

    def fit_text(text, max_width, font_name='Helvetica', font_size=8):
        text = str(text or '-')

        if p.stringWidth(text, font_name, font_size) <= max_width:
            return text

        ellipsis = '...'
        available = max_width - p.stringWidth(ellipsis, font_name, font_size)

        trimmed = ''

        for char in text:
            if p.stringWidth(trimmed + char, font_name, font_size) > available:
                break

            trimmed += char

        return trimmed.rstrip() + ellipsis

    def draw_page_background():
        p.setFillColor(soft)
        p.rect(0, 0, width, height, fill=1, stroke=0)

        p.setFillColor(colors.white)
        p.roundRect(card_x, card_y, card_w, card_h, 16, fill=1, stroke=0)

        p.setStrokeColor(border)
        p.setLineWidth(1)
        p.roundRect(card_x, card_y, card_w, card_h, 16, fill=0, stroke=1)

    def draw_header():
        header_top = height - 64

        if os.path.exists(logo_path):
            p.drawImage(
                logo_path,
                inner_x,
                header_top - 40,
                width=38,
                height=38,
                preserveAspectRatio=True,
                mask='auto'
            )

            title_x = inner_x + 48
        else:
            title_x = inner_x

        p.setFillColor(dark)
        p.setFont('Helvetica-Bold', 16)
        p.drawString(title_x, header_top - 6, 'University of Global Village (UGV)')

        p.setFillColor(muted)
        p.setFont('Helvetica', 8.5)
        p.drawString(title_x, header_top - 23, 'Office of the Exam Controller')

        p.setFillColor(accent)
        p.setFont('Helvetica-Bold', 13)
        p.drawRightString(right_x, header_top - 6, 'OFFICIAL TRANSCRIPT')

        p.setFillColor(muted)
        p.setFont('Helvetica', 8)
        p.drawRightString(right_x, header_top - 23, f'Issue Date: {timezone.localdate()}')

        line_y = header_top - 46

        p.setStrokeColor(accent)
        p.setLineWidth(5)
        p.line(inner_x, line_y, right_x, line_y)

        p.setStrokeColor(border)
        p.setLineWidth(1)
        p.line(inner_x, line_y - 22, right_x, line_y - 22)

        return line_y - 50

    def draw_footer():
        footer_y = 82

        p.setStrokeColor(border)
        p.setLineWidth(1)

        p.line(inner_x + 16, footer_y + 24, inner_x + 116, footer_y + 24)
        p.line(inner_x + 205, footer_y + 24, inner_x + 305, footer_y + 24)
        p.line(right_x - 116, footer_y + 24, right_x - 16, footer_y + 24)

        p.setFillColor(muted)
        p.setFont('Helvetica', 8)
        p.drawString(inner_x + 36, footer_y + 10, 'Prepared By')
        p.drawString(inner_x + 226, footer_y + 10, 'Checked By')
        p.drawString(right_x - 98, footer_y + 10, 'Exam Controller')

        p.setFillColor(accent)
        p.setFont('Helvetica-Bold', 8)
        p.drawRightString(right_x, 54, 'UGV Smart University Portal')

    def draw_label_value(x, y, label, value, value_width=190):
        p.setFillColor(muted)
        p.setFont('Helvetica', 8)
        p.drawString(x, y, label)

        p.setFillColor(dark)
        p.setFont('Helvetica-Bold', 9.5)
        p.drawString(x, y - 13, fit_text(value, value_width, 'Helvetica-Bold', 9.5))

    def draw_table_header(y):
        p.setFillColor(table_head)
        p.roundRect(table_x, y - 8, table_w, 24, 8, fill=1, stroke=0)

        p.setFillColor(muted)
        p.setFont('Helvetica-Bold', 7.2)

        p.drawString(table_x + 10, y, 'COURSE CODE')
        p.drawString(table_x + 92, y, 'COURSE TITLE')
        p.drawRightString(table_x + 320, y, 'CREDIT')
        p.drawRightString(table_x + 370, y, 'GRADE')
        p.drawRightString(table_x + 415, y, 'GP')
        p.drawString(table_x + 430, y, 'REMARKS')

        return y - 24

    draw_page_background()
    y = draw_header()

    p.setFillColor(dark)
    p.setFont('Helvetica-Bold', 12)
    p.drawString(inner_x, y, 'Student Information')

    y -= 26

    draw_label_value(inner_x, y, 'Student Name', _user_display_name(student.user), 220)
    draw_label_value(332, y, 'Student ID', student.student_id, 150)

    y -= 42

    draw_label_value(inner_x, y, 'Department', str(student.department or '-'), 220)
    draw_label_value(332, y, 'Batch', str(student.batch or '-'), 150)

    y -= 42

    draw_label_value(inner_x, y, 'Semester', str(semester or '-'), 220)
    draw_label_value(332, y, 'Current Semester', str(student.current_semester or '-'), 150)

    y -= 36

    p.setStrokeColor(border)
    p.setLineWidth(1)
    p.line(inner_x, y, right_x, y)

    y -= 26

    p.setFillColor(accent)
    p.setFont('Helvetica-Bold', 12)
    p.drawString(inner_x, y, 'Academic Record')

    p.setFillColor(muted)
    p.setFont('Helvetica', 8)
    p.drawRightString(right_x, y, 'Final published results only')

    y -= 24
    y = draw_table_header(y)

    p.setFont('Helvetica', 7.8)

    for mark in marks:
        if y < 170:
            draw_footer()
            p.showPage()

            draw_page_background()
            y = draw_header()

            p.setFillColor(accent)
            p.setFont('Helvetica-Bold', 12)
            p.drawString(inner_x, y, 'Academic Record Continued')

            y -= 24
            y = draw_table_header(y)

        course = mark.course_offering.course

        if str(mark.grade).upper() == 'F':
            remarks = 'Failed'
        else:
            remarks = 'Completed'

        p.setFillColor(dark)
        p.setFont('Helvetica', 7.8)

        p.drawString(
            table_x + 10,
            y,
            fit_text(course.code, 74, 'Helvetica', 7.8)
        )

        p.drawString(
            table_x + 92,
            y,
            fit_text(course.title, 205, 'Helvetica', 7.8)
        )

        p.drawRightString(
            table_x + 320,
            y,
            str(course.credit or '0')
        )

        p.drawRightString(
            table_x + 370,
            y,
            str(mark.grade or '-')
        )

        p.drawRightString(
            table_x + 415,
            y,
            str(mark.grade_point or '0')
        )

        p.drawString(
            table_x + 430,
            y,
            fit_text(remarks, 55, 'Helvetica', 7.8)
        )

        p.setStrokeColor(border)
        p.setLineWidth(1)
        p.line(table_x, y - 9, table_x + table_w, y - 9)

        y -= 20

    y -= 20

    if y < 210:
        draw_footer()
        p.showPage()

        draw_page_background()
        y = draw_header()

    summary_h = 68

    p.setFillColor(soft)
    p.roundRect(table_x, y - summary_h, table_w, summary_h, 12, fill=1, stroke=0)

    p.setStrokeColor(border)
    p.setLineWidth(1)
    p.roundRect(table_x, y - summary_h, table_w, summary_h, 12, fill=0, stroke=1)

    summary_items = [
        ('SEMESTER CREDITS', str(semester_total_credits)),
        ('SEMESTER GPA', str(semester_cgpa)),
        ('TOTAL COMPLETED CREDITS', str(total_credits)),
        ('CUMULATIVE GPA', str(overall_cgpa)),
    ]

    summary_col_w = table_w / 4

    for index, item in enumerate(summary_items):
        label, value = item
        x = table_x + 16 + (summary_col_w * index)

        p.setFillColor(muted)
        p.setFont('Helvetica-Bold', 7)
        p.drawString(x, y - 22, label)

        p.setFillColor(dark)
        p.setFont('Helvetica-Bold', 13)
        p.drawString(x, y - 44, value)

    y -= summary_h + 18

    note_text = (
        'This transcript is generated from officially published final results. '
        'Detailed component marks are shown in the official mark sheet, not in the transcript.'
    )

    p.setFillColor(muted)
    p.setFont('Helvetica', 7)
    p.drawString(
        table_x,
        y,
        fit_text(note_text, table_w, 'Helvetica', 7)
    )

    draw_footer()

    p.showPage()
    p.save()

    return response


@login_required
