def exam_result_correction_request(request, mark_id):
    if request.user.role != 'exam_controller':
        return redirect('dashboard')

    mark = get_object_or_404(
        Mark.objects.select_related(
            'student',
            'student__user',
            'student__department',
            'student__batch',
            'student__current_semester',
            'course_offering',
            'course_offering__course',
            'course_offering__semester',
            'course_offering__faculty',
            'submitted_by',
            'last_updated_by',
        ),
        id=mark_id,
        is_submitted=True
    )

    pending_request = ResultCorrectionRequest.objects.filter(
        mark=mark,
        status='pending'
    ).first()

    if request.method == 'POST':
        if pending_request:
            messages.warning(
                request,
                'A pending correction request already exists for this result.'
            )
            return redirect(
                'exam_student_result_detail',
                student_id=mark.student.id
            )

        reason = request.POST.get('reason', '').strip()

        new_class_test = Decimal(request.POST.get('class_test') or '0')
        new_assignment = Decimal(request.POST.get('assignment') or '0')
        new_attendance = Decimal(request.POST.get('attendance') or '0')
        new_midterm = Decimal(request.POST.get('midterm') or '0')
        new_final = Decimal(request.POST.get('final') or '0')

        if not reason:
            messages.error(request, 'Please write a reason for this correction request.')
            return redirect(
                'exam_result_correction_request',
                mark_id=mark.id
            )

        ResultCorrectionRequest.objects.create(
            mark=mark,
            student=mark.student,
            course_offering=mark.course_offering,

            requested_by=request.user,
            reason=reason,

            old_class_test=mark.class_test,
            old_assignment=mark.assignment,
            old_attendance=mark.attendance,
            old_midterm=mark.midterm,
            old_final=mark.final,

            new_class_test=new_class_test,
            new_assignment=new_assignment,
            new_attendance=new_attendance,
            new_midterm=new_midterm,
            new_final=new_final,
        )

        messages.success(
            request,
            'Correction request sent to super admin successfully.'
        )

        return redirect(
            'exam_student_result_detail',
            student_id=mark.student.id
        )

    correction_requests = ResultCorrectionRequest.objects.filter(
        mark=mark
    ).select_related(
        'requested_by',
        'reviewed_by'
    ).order_by('-created_at')

    context = {
        'mark': mark,
        'pending_request': pending_request,
        'correction_requests': correction_requests,
    }

    return render(request, 'dashboard/exam_result_correction_request.html', context)


