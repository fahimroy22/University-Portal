        'selected_department_id': selected_department_id,

        'course_offerings': course_offerings,
        'students': students,
        'faculty_users': faculty_users,
        'routines': routines,
        'seat_plans': seat_plans,
        'hall_duties': hall_duties,
        'result_publications': result_publications,
        'semesters': semesters,
    }


def _redirect_exam_action(request, url_name):
    selected_department_id = request.POST.get('selected_department_id')

    base_url = reverse(url_name)

    if selected_department_id:
        return redirect(f'{base_url}?department={selected_department_id}')

    return redirect(url_name)


def _routine_redirect_url(department_id=None, semester_id=None, exam_type=None, section=None):
    base_url = reverse('exam_create_routine')
    query_parts = []

    if department_id:
        query_parts.append(f'department={department_id}')

    if semester_id:
        query_parts.append(f'routine_semester={semester_id}')

    if exam_type:
        query_parts.append(f'routine_exam_type={exam_type}')

    if section:
        query_parts.append(f'routine_section={section}')

    if query_parts:
        return f'{base_url}?{"&".join(query_parts)}'

    return base_url


def _get_semester_routine_course_offerings(department_id, semester_id, section=None):
    if not department_id or not semester_id:
        return CourseOffering.objects.none()

    course_offerings = CourseOffering.objects.filter(
        semester_id=semester_id
    ).filter(
        Q(course__department_id=department_id) |
        Q(batch__department_id=department_id)
    ).select_related(
        'course',
        'course__department',
        'batch',
        'batch__department',
        'semester',
        'faculty'
    )

    if section:
        course_offerings = course_offerings.filter(section=section)

    return course_offerings.order_by(
        'course__code',
        'section'
    )


def _get_routine_scope_label(department_id, semester_id, exam_type):
    department = None
    semester = None

    if department_id:
        department = Department.objects.filter(id=department_id).first()

    if semester_id:
        offering = CourseOffering.objects.filter(
            semester_id=semester_id
        ).select_related(
            'semester'
        ).first()

        if offering:
            semester = offering.semester

    return department, semester, exam_type


