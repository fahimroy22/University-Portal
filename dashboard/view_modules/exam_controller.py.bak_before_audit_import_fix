@login_required
def exam_create_routine(request):
    if request.user.role != 'exam_controller':
        return redirect('dashboard')

    selected_department_id = (
        request.GET.get('department') or
        request.POST.get('selected_department_id') or
        ''
    )

    selected_routine_semester_id = (
        request.GET.get('routine_semester') or
        request.POST.get('routine_semester') or
        ''
    )

    selected_routine_exam_type = (
        request.GET.get('routine_exam_type') or
        request.POST.get('routine_exam_type') or
        'midterm'
    )

    selected_routine_section = (
        request.GET.get('routine_section') or
        request.POST.get('routine_section') or
        ''
    )

    if request.method == 'POST':
        action = request.POST.get('action')

        if action == 'create_routine':
            course_offering_id = request.POST.get('course_offering')
            exam_type = request.POST.get('exam_type')
            exam_date = request.POST.get('exam_date')
            start_time = request.POST.get('start_time')
            end_time = request.POST.get('end_time')
            room = request.POST.get('room')
            is_published = request.POST.get('is_published') == 'on'

            course_offering = CourseOffering.objects.filter(
                id=course_offering_id
            ).first()

            if course_offering and exam_type and exam_date and start_time and end_time and room:
                routine, created = ExamRoutine.objects.update_or_create(
                    course_offering=course_offering,
                    exam_type=exam_type,
                    defaults={
                        'exam_date': exam_date,
                        'start_time': start_time,
                        'end_time': end_time,
                        'room': room,
                        'is_published': is_published,
                    }
                )

                if created:
                    messages.success(request, 'Exam routine created successfully.')
                else:
                    messages.success(request, 'Exam routine updated successfully.')
            else:
                messages.error(request, 'Please fill all exam routine fields.')

            return redirect(
                _routine_redirect_url(
                    selected_department_id,
                    selected_routine_semester_id,
                    selected_routine_exam_type,
                    selected_routine_section
                )
            )

        if action == 'save_semester_routine':
            department_id = request.POST.get('selected_department_id', '').strip()
            semester_id = request.POST.get('routine_semester', '').strip()
            exam_type = request.POST.get('routine_exam_type', '').strip()
            section = request.POST.get('routine_section', '').strip()
            publish_mode = request.POST.get('publish_mode', 'draft').strip()

            if not department_id or not semester_id or not exam_type:
                messages.error(request, 'Please select department, semester, and exam type first.')
                return redirect('exam_create_routine')

            course_offerings = _get_semester_routine_course_offerings(
                department_id,
                semester_id,
                section
            )

            saved_count = 0
            skipped_count = 0

            for offering in course_offerings:
                date_value = request.POST.get(f'exam_date_{offering.id}', '').strip()
                start_value = request.POST.get(f'start_time_{offering.id}', '').strip()
                end_value = request.POST.get(f'end_time_{offering.id}', '').strip()
                room_value = request.POST.get(f'room_{offering.id}', '').strip()

                has_any_value = date_value or start_value or end_value or room_value
                has_all_values = date_value and start_value and end_value and room_value

                if not has_any_value:
                    skipped_count += 1
                    continue

                if not has_all_values:
                    skipped_count += 1
                    continue

                ExamRoutine.objects.update_or_create(
                    course_offering=offering,
                    exam_type=exam_type,
                    defaults={
                        'exam_date': date_value,
                        'start_time': start_value,
                        'end_time': end_value,
                        'room': room_value,
                        'is_published': publish_mode == 'publish',
                    }
                )

                saved_count += 1

            if publish_mode == 'publish':
                messages.success(
                    request,
                    f'{saved_count} {_exam_type_display(exam_type)} routine(s) saved and published. {skipped_count} course(s) skipped.'
                )
            else:
                messages.success(
                    request,
                    f'{saved_count} {_exam_type_display(exam_type)} routine(s) saved as draft. {skipped_count} course(s) skipped.'
                )

            return redirect(
                _routine_redirect_url(
                    department_id,
                    semester_id,
                    exam_type,
                    section
                )
            )

        if action == 'toggle_routine':
            routine_id = request.POST.get('routine_id')

            routine = ExamRoutine.objects.filter(
                id=routine_id
            ).first()

            if routine:
                routine.is_published = not routine.is_published
                routine.save()

                if routine.is_published:
                    messages.success(request, 'Exam routine published.')
                else:
                    messages.warning(request, 'Exam routine unpublished.')
            else:
                messages.error(request, 'Exam routine not found.')

            return redirect(
                _routine_redirect_url(
                    selected_department_id,
                    selected_routine_semester_id,
                    selected_routine_exam_type,
                    selected_routine_section
                )
            )

    context = _exam_controller_base_context(request)

    available_sections = []

    if selected_department_id and selected_routine_semester_id:
        section_queryset = CourseOffering.objects.filter(
            semester_id=selected_routine_semester_id
        ).filter(
            Q(course__department_id=selected_department_id) |
            Q(batch__department_id=selected_department_id)
        ).exclude(
            section__isnull=True
        ).exclude(
            section=''
        ).values_list(
            'section',
            flat=True
        ).distinct().order_by('section')

        available_sections = list(section_queryset)

    semester_builder_offerings = _get_semester_routine_course_offerings(
        selected_department_id,
        selected_routine_semester_id,
        selected_routine_section
    )

    existing_routine_map = {}

    if selected_routine_exam_type:
        existing_routines = ExamRoutine.objects.filter(
            course_offering_id__in=semester_builder_offerings.values_list('id', flat=True),
            exam_type=selected_routine_exam_type
        ).select_related(
            'course_offering',
            'course_offering__course',
            'course_offering__batch',
            'course_offering__semester'
        )

        for routine in existing_routines:
            existing_routine_map[routine.course_offering_id] = routine

    semester_builder_rows = []

    for offering in semester_builder_offerings:
        semester_builder_rows.append({
            'offering': offering,
            'routine': existing_routine_map.get(offering.id),
        })

    scope_department, scope_semester, scope_exam_type = _get_routine_scope_label(
        selected_department_id,
        selected_routine_semester_id,
        selected_routine_exam_type
    )

    semester_scope_routines = ExamRoutine.objects.none()

    if selected_department_id and selected_routine_semester_id and selected_routine_exam_type:
        semester_scope_routines = ExamRoutine.objects.filter(
            course_offering_id__in=semester_builder_offerings.values_list('id', flat=True),
            exam_type=selected_routine_exam_type
        ).select_related(
            'course_offering',
            'course_offering__course',
            'course_offering__batch',
            'course_offering__semester',
            'course_offering__faculty'
        ).order_by(
            'exam_date',
            'start_time',
            'course_offering__course__code'
        )

    context.update({
        'page_type': 'routine',
        'page_title': 'Create Exam Routine',
        'page_subtitle': 'Create individual, semester-wise, and recovery exam routines.',

        'selected_routine_semester_id': selected_routine_semester_id,
        'selected_routine_exam_type': selected_routine_exam_type,
        'selected_routine_section': selected_routine_section,
        'available_sections': available_sections,

        'semester_builder_rows': semester_builder_rows,
        'semester_scope_routines': semester_scope_routines,

        'scope_department': scope_department,
        'scope_semester': scope_semester,
        'scope_exam_type': scope_exam_type,
        'scope_exam_type_display': _exam_type_display(scope_exam_type),
    })

    return render(request, 'dashboard/exam_controller_action_page.html', context)


