    if not department_id or not semester_id or not exam_type:
        messages.error(request, 'Please select department, semester, and exam type.')
        return redirect('exam_publish_result')

    department = get_object_or_404(Department, id=department_id)

    course_offerings = CourseOffering.objects.filter(
        semester_id=semester_id
    ).filter(
        Q(course__department_id=department_id) |
        Q(batch__department_id=department_id)
    ).select_related(
        'course',
        'course__department',
        'batch',
        'batch__department',
        'semester',
        'faculty'
    ).order_by(
        'course__code',
        'section'
    )

    semester = None

    if course_offerings.exists():
        semester = course_offerings.first().semester

    course_rows = []
    ready_count = 0

    for offering in course_offerings:
        registrations = CourseRegistration.objects.filter(
            course_offering=offering,
            status='approved'
        ).select_related(
            'student',
            'student__user'
        ).order_by(
            'student__student_id'
        )

        total_students = registrations.count()

        marks = Mark.objects.filter(
            course_offering=offering,
            is_submitted=True
        ).select_related(
            'student',
            'student__user'
        )

        submitted_count = marks.count()
        missing_count = max(total_students - submitted_count, 0)

        publication = ResultPublication.objects.filter(
            course_offering=offering,
            exam_type=exam_type
        ).select_related(
            'published_by'
        ).first()

        total_sum = Decimal('0')
        mark_count = 0

        for mark in marks:
            if exam_type == 'midterm':
                total_sum += (
                    mark.class_test +
                    mark.assignment +
                    mark.attendance +
                    mark.midterm
                )
            else:
                total_sum += mark.total

            mark_count += 1

        if mark_count > 0:
            average_marks = round(total_sum / mark_count, 2)
        else:
            average_marks = None

        is_ready = submitted_count > 0

        if is_ready:
            ready_count += 1

        student_rows = []

        for reg in registrations:
            mark = marks.filter(student=reg.student).first()

            if mark:
                if exam_type == 'midterm':
                    shown_total = (
                        mark.class_test +
                        mark.assignment +
                        mark.attendance +
                        mark.midterm
                    )
                    total_label = f'{shown_total}/90'
                else:
                    shown_total = mark.total
                    total_label = f'{mark.total}/100'

                student_rows.append({
                    'student': reg.student,
                    'mark': mark,
                    'total_label': total_label,
                    'status': 'Submitted',
                })
            else:
                student_rows.append({
                    'student': reg.student,
                    'mark': None,
                    'total_label': '-',
                    'status': 'Not Submitted',
                })

        course_rows.append({
            'offering': offering,
            'course_offering': offering,

            'student_rows': student_rows,

            'total_students': total_students,

            'submitted_count': submitted_count,
            'submitted_marks': submitted_count,

            'missing_count': missing_count,
            'missing_marks': missing_count,

            'average_marks': average_marks,
            'average_total': average_marks,

            'publication': publication,
            'is_ready': is_ready,

            'preview_url': (
                f'{reverse("exam_result_preview")}'
                f'?course_offering={offering.id}&exam_type={exam_type}'
            ),
        })

    context = {
        'department': department,
        'semester': semester,
        'exam_type': exam_type,
        'course_rows': course_rows,
        'total_courses': course_offerings.count(),

        'ready_count': ready_count,
        'ready_courses': ready_count,

        'department_id': department_id,
        'semester_id': semester_id,
    }

    return render(request, 'dashboard/exam_semester_result_review.html', context)


