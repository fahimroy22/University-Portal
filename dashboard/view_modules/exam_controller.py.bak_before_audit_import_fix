@login_required
def exam_student_result_detail(request, student_id):
    if request.user.role != 'exam_controller':
        return redirect('dashboard')

    student = get_object_or_404(
        StudentProfile.objects.select_related(
            'user',
            'department',
            'batch',
            'current_semester'
        ),
        id=student_id
    )

    selected_semester_id = request.GET.get('semester', '').strip()
    selected_exam_type = request.GET.get('exam_type', '').strip()

    marks = Mark.objects.filter(
        student=student,
        is_submitted=True
    ).select_related(
        'student',
        'student__user',
        'course_offering',
        'course_offering__course',
        'course_offering__course__department',
        'course_offering__batch',
        'course_offering__semester',
        'course_offering__faculty',
        'submitted_by',
        'last_updated_by',
    ).order_by(
        'course_offering__semester__id',
        'course_offering__course__code'
    )

    if selected_semester_id:
        marks = marks.filter(
            course_offering__semester_id=selected_semester_id
        )

    course_offering_ids = marks.values_list(
        'course_offering_id',
        flat=True
    )

    publications = ResultPublication.objects.filter(
        course_offering_id__in=course_offering_ids
    ).select_related(
        'published_by',
        'course_offering'
    )

    publication_map = {}

    for publication in publications:
        publication_map[
            (publication.course_offering_id, publication.exam_type)
        ] = publication

    grouped = defaultdict(list)

    for mark in marks:
        semester = mark.course_offering.semester

        midterm_publication = publication_map.get(
            (mark.course_offering_id, 'midterm')
        )

        final_publication = publication_map.get(
            (mark.course_offering_id, 'final')
        )

        if selected_exam_type == 'midterm' and not midterm_publication:
            continue

        if selected_exam_type == 'final' and not final_publication:
            continue

        midterm_total = (
            mark.class_test +
            mark.assignment +
            mark.attendance +
            mark.midterm
        )

        submitted_by = mark.submitted_by or mark.course_offering.faculty
        submitted_by_meta = _faculty_department_designation(
            submitted_by,
            mark.course_offering.course.department
        )

        grouped[semester].append({
            'mark': mark,
            'midterm_total': midterm_total,
            'midterm_publication': midterm_publication,
            'final_publication': final_publication,
            'submitted_by': submitted_by,
            'submitted_by_meta': submitted_by_meta,
        })

    semester_groups = []

    for semester, rows in grouped.items():
        semester_total_credits = Decimal('0')
        semester_weighted_points = Decimal('0')

        used_course_ids = set()

        for row in rows:
            mark = row['mark']
            final_publication = row['final_publication']

            if (
                final_publication and
                final_publication.is_published and
                mark.course_offering_id not in used_course_ids
            ):
                used_course_ids.add(mark.course_offering_id)

                credit = Decimal(str(mark.course_offering.course.credit or 0))
                grade_point = Decimal(str(mark.grade_point or 0))

                semester_total_credits += credit
                semester_weighted_points += credit * grade_point

        if semester_total_credits > 0:
            semester_cgpa = round(
                semester_weighted_points / semester_total_credits,
                2
            )
        else:
            semester_cgpa = None

        transcript_url = ''

        if semester:
            transcript_url = reverse(
                'download_semester_transcript_by_student',
                args=[student.id, semester.id]
            )

        semester_groups.append({
            'semester': semester,
            'rows': rows,
            'semester_total_credits': semester_total_credits,
            'semester_cgpa': semester_cgpa,
            'transcript_url': transcript_url,
        })

    all_semesters = []
    used_semester_ids = set()

    course_offerings_for_semesters = CourseOffering.objects.select_related(
        'semester'
    ).exclude(
        semester__isnull=True
    ).order_by(
        'semester__id'
    )

    for offering in course_offerings_for_semesters:
        if offering.semester and offering.semester.id not in used_semester_ids:
            all_semesters.append(offering.semester)
            used_semester_ids.add(offering.semester.id)

    context = {
        'student': student,
        'semester_groups': semester_groups,
        'semesters': all_semesters,
        'selected_semester_id': selected_semester_id,
        'selected_exam_type': selected_exam_type,
    }

    return render(request, 'dashboard/exam_student_result_detail.html', context)


