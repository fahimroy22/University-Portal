@login_required
def review_result_correction_request(request, request_id):
    if request.user.role != 'super_admin':
        return redirect('dashboard')

    correction_request = get_object_or_404(
        ResultCorrectionRequest.objects.select_related(
            'mark',
            'student',
            'student__user',
            'student__department',
            'student__batch',
            'student__current_semester',
            'course_offering',
            'course_offering__course',
            'course_offering__batch',
            'course_offering__semester',
            'course_offering__faculty',
            'requested_by',
            'reviewed_by',
        ),
        id=request_id
    )

    if request.method == 'POST':
        if correction_request.status != 'pending':
            messages.warning(
                request,
                'This correction request has already been reviewed.'
            )
            return redirect(
                'review_result_correction_request',
                request_id=correction_request.id
            )

        action = request.POST.get('action')
        admin_note = request.POST.get('admin_note', '').strip()

        if action == 'approve':
            correction_request.approve(request.user)

            create_audit_log(
                request,
                action='APPROVE',
                module='Result Corrections',
                description=(
                    f'Approved result correction request for '
                    f'{correction_request.student.student_id} - '
                    f'{correction_request.course_offering.course.code}'
                ),
                target_model='ResultCorrectionRequest',
                target_id=correction_request.id,
                target_repr=str(correction_request),
            )

            messages.success(
                request,
                'Result correction approved and marks updated successfully.'
            )

        elif action == 'reject':
            correction_request.reject(
                request.user,
                admin_note
            )

            create_audit_log(
                request,
                action='REJECT',
                module='Result Corrections',
                description=(
                    f'Rejected result correction request for '
                    f'{correction_request.student.student_id} - '
                    f'{correction_request.course_offering.course.code}'
                ),
                target_model='ResultCorrectionRequest',
                target_id=correction_request.id,
                target_repr=str(correction_request),
            )

            messages.warning(
                request,
                'Result correction request rejected.'
            )

        else:
            messages.error(
                request,
                'Invalid review action.'
            )

        return redirect(
            'review_result_correction_request',
            request_id=correction_request.id
        )

    mark_changes = [
        {
            'label': 'Class Test',
            'old': correction_request.old_class_test,
            'new': correction_request.new_class_test,
        },
        {
            'label': 'Assignment',
            'old': correction_request.old_assignment,
            'new': correction_request.new_assignment,
        },
        {
            'label': 'Attendance',
            'old': correction_request.old_attendance,
            'new': correction_request.new_attendance,
        },
        {
            'label': 'Midterm',
            'old': correction_request.old_midterm,
            'new': correction_request.new_midterm,
        },
        {
            'label': 'Final',
            'old': correction_request.old_final,
            'new': correction_request.new_final,
        },
    ]

    for item in mark_changes:
        item['changed'] = item['old'] != item['new']
        item['difference'] = item['new'] - item['old']

    context = {
        'correction_request': correction_request,
        'mark_changes': mark_changes,
        'is_pending': correction_request.status == 'pending',
    }

    return render(
        request,
        'dashboard/review_result_correction_request.html',
        context
    )


