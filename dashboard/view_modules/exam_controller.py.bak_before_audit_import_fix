def _user_display_name(user):
    if not user:
        return '-'

    return user.get_full_name() or user.username


def _department_label(department):
    if not department:
        return '-'

    if hasattr(department, 'code') and department.code:
        return department.code

    if hasattr(department, 'name') and department.name:
        return department.name

    return str(department)


def _faculty_department_designation(user, fallback_department=None):
    if not user:
        return '-'

    department = None

    if hasattr(user, 'staff_department') and user.staff_department:
        department = user.staff_department
    elif fallback_department:
        department = _department_label(fallback_department)

    designation = None

    if hasattr(user, 'designation') and user.designation:
        designation = user.designation
    elif hasattr(user, 'get_role_display'):
        designation = user.get_role_display()

    if department and designation:
        return f'{department} · {designation}'

    if department:
        return str(department)

    if designation:
        return str(designation)

    return '-'


def _exam_type_display(exam_type):
    labels = {
        'midterm': 'Midterm',
        'final': 'Final',
        'recovery': 'Recovery',
    }

    return labels.get(exam_type, str(exam_type).title())


def _get_semesters_from_course_offerings(queryset):
    semesters = []
    used_semester_ids = set()

    for offering in queryset:
        if offering.semester and offering.semester.id not in used_semester_ids:
            semesters.append(offering.semester)
            used_semester_ids.add(offering.semester.id)

    return semesters


def _exam_controller_base_context(request):
    selected_department_id = (
        request.GET.get('department') or
        request.POST.get('selected_department_id')
    )

    departments = Department.objects.all().order_by('name')

    course_offerings = CourseOffering.objects.select_related(
        'course',
        'course__department',
        'batch',
        'batch__department',
        'semester',
        'faculty'
    )

    students = StudentProfile.objects.select_related(
        'user',
        'department',
        'batch',
        'current_semester'
    )

    routines = ExamRoutine.objects.select_related(
        'course_offering',
        'course_offering__course',
        'course_offering__batch',
        'course_offering__semester'
    )

    seat_plans = SeatPlan.objects.select_related(
        'student',
        'student__user',
        'course_offering',
        'course_offering__course'
    )

    hall_duties = HallDuty.objects.select_related(
        'faculty',
        'exam_routine',
        'exam_routine__course_offering',
        'exam_routine__course_offering__course'
    )

    result_publications = ResultPublication.objects.select_related(
        'course_offering',
        'course_offering__course',
        'course_offering__batch',
        'course_offering__semester',
        'published_by'
    )

    if selected_department_id:
        course_offerings = course_offerings.filter(
            Q(course__department_id=selected_department_id) |
            Q(batch__department_id=selected_department_id)
        )

        students = students.filter(
            department_id=selected_department_id
        )

        routines = routines.filter(
            Q(course_offering__course__department_id=selected_department_id) |
            Q(course_offering__batch__department_id=selected_department_id)
        )

        seat_plans = seat_plans.filter(
            Q(course_offering__course__department_id=selected_department_id) |
            Q(course_offering__batch__department_id=selected_department_id)
        )

        hall_duties = hall_duties.filter(
            Q(exam_routine__course_offering__course__department_id=selected_department_id) |
            Q(exam_routine__course_offering__batch__department_id=selected_department_id)
        )

        result_publications = result_publications.filter(
            Q(course_offering__course__department_id=selected_department_id) |
            Q(course_offering__batch__department_id=selected_department_id)
        )

    course_offerings = course_offerings.order_by(
        'semester__id',
        'course__code',
        'section'
    )

    students = students.order_by('student_id')

    routines = routines.order_by(
        '-exam_date',
        '-id'
    )

    seat_plans = seat_plans.order_by(
        'course_offering__course__code',
        'student__student_id'
    )

    hall_duties = hall_duties.order_by('-id')

    result_publications = result_publications.order_by(
